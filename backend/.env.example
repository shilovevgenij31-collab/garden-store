# Environment
ENV=development
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./garden.db

# URLs
FRONTEND_URL=http://localhost:5173
BASE_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# Admin authentication
# Generate a hash:  python scripts/hash_password.py
# Then paste the output here:
ADMIN_PASSWORD_HASH=
# Legacy (plain text, NOT recommended — will be hashed in memory at startup):
# ADMIN_PASSWORD=

# Token signing key (auto-generated if empty; set for persistent tokens across restarts)
SECRET_KEY=

# File uploads
UPLOAD_DIR=./uploads
STORAGE_BACKEND=local

# Rate limiting
RATE_LIMIT_ORDERS=5/minute
RATE_LIMIT_PRODUCTS=60/minute
RATE_LIMIT_ADMIN_LOGIN=5/minute

# Integrations (stubs)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
